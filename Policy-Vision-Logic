                                                <tr>
                                                    <th className="px-6 py-3 text-left text-xs font-bold text-slate-600 uppercase tracking-wider w-1/5">年齡</th>
                                                    <th className="px-6 py-3 text-left text-xs font-bold text-slate-600 uppercase tracking-wider w-1/4">累積保費</th>
                                                    <th className="px-6 py-3 text-left text-xs font-bold text-slate-600 uppercase tracking-wider w-1/4">保險額度</th>
                                                    <th className="px-6 py-3 text-left text-xs font-bold text-slate-600 uppercase tracking-wider w-1/4">解約金</th>
                                                </tr>
                                            </thead>
                                            <tbody className="bg-white divide-y divide-slate-200">
                                                {extractedData.length > 0 ? extractedData.map((row) => (
                                                    <tr key={row.id} className="hover:bg-slate-50 transition-colors">
                                                        <td className="px-6 py-3"><input type="text" value={row.age} onChange={(e) => handleDataChange(row.id, 'age', e.target.value)} className="w-full bg-transparent border-b border-transparent focus:border-blue-500 focus:outline-none text-slate-900 font-medium" /></td>
                                                        <td className="px-6 py-3"><input type="text" value={row.accPremium} onChange={(e) => handleDataChange(row.id, 'accPremium', e.target.value)} className="w-full bg-transparent border-b border-transparent focus:border-blue-500 focus:outline-none text-green-700 font-medium" /></td>
                                                        <td className="px-6 py-3"><input type="text" value={row.insurance} onChange={(e) => handleDataChange(row.id, 'insurance', e.target.value)} className="w-full bg-transparent border-b border-transparent focus:border-blue-500 focus:outline-none text-blue-700 font-medium" /></td>
                                                        <td className="px-6 py-3"><input type="text" value={row.surrender} onChange={(e) => handleDataChange(row.id, 'surrender', e.target.value)} className="w-full bg-transparent border-b border-transparent focus:border-blue-500 focus:outline-none text-red-600 font-medium" /></td>
                                                    </tr>
                                                )) : (
                                                    <tr><td colSpan="4" className="px-6 py-10 text-center text-slate-500">未偵測到符合的數據。</td></tr>
                                                )}
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            )}

                            {/* STEP 3: CHART */}
                            {step === 3 && (
                                <div>
                                    <div className="flex justify-between items-center mb-6">
                                        <h2 className="text-xl font-bold text-slate-800">保單價值走勢圖</h2>
                                        <div className="flex gap-2">
                                            <button onClick={reset} className="px-4 py-2 text-sm text-slate-600 border border-slate-300 rounded hover:bg-slate-50">重新開始</button>
                                            <button onClick={() => setStep(2)} className="px-4 py-2 text-sm text-slate-600 border border-slate-300 rounded hover:bg-slate-50">返回表格</button>
                                        </div>
                                    </div>
                                    <div className="bg-white p-4 rounded-lg border border-slate-200 shadow-sm h-[600px]">
                                        <ResponsiveContainer width="100%" height="100%">
                                            <LineChart data={chartData} margin={{ top: 20, right: 30, left: 20, bottom: 20 }}>
                                                <CartesianGrid strokeDasharray="3 3" vertical={false} stroke="#e2e8f0" />
                                                <XAxis dataKey="age" label={{ value: '年齡', position: 'insideBottomRight', offset: -10 }} tick={{ fill: '#64748b' }} axisLine={{ stroke: '#cbd5e1' }} />
                                                <YAxis tickFormatter={(value) => `$${value / 1000}k`} tick={{ fill: '#64748b' }} axisLine={{ stroke: '#cbd5e1' }} />
                                                <Tooltip formatter={(value) => formatMoney(value)} labelFormatter={(label) => `${label} 歲`} contentStyle={{ backgroundColor: 'rgba(255, 255, 255, 0.95)', borderRadius: '8px', border: '1px solid #e2e8f0' }} />
                                                <Legend verticalAlign="top" height={36} />
                                                <Line type="monotone" dataKey="insurance" name="保險額度 (壽險)" stroke="#2563eb" strokeWidth={3} dot={false} activeDot={{ r: 8 }} />
                                                <Line type="monotone" dataKey="surrender" name="解約金 (預估)" stroke="#dc2626" strokeWidth={3} dot={false} activeDot={{ r: 8 }} />
                                                <Line type="monotone" dataKey="accPremium" name="累積保費" stroke="#16a34a" strokeWidth={3} dot={false} strokeDasharray="5 5" activeDot={{ r: 8 }} />
                                            </LineChart>
                                        </ResponsiveContainer>
                                    </div>
                                    <div className="mt-4 text-center text-sm text-slate-500"><span className="text-green-600 font-bold">--- 累積保費</span> 代表投入成本，當紅線超越綠線時，即代表已回本。</div>
                                </div>
                            )}
                        </div>
                    </div>
                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<PolicyExtractor />);
    </script>
</body>
</html>
