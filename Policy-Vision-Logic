            const processPDF = async () => {
                if (!file) return;
                setProcessing(true);
                setExtractedData([]);
                setError('');

                try {
                    const arrayBuffer = await file.arrayBuffer();
                    const pdf = await window.pdfjsLib.getDocument(arrayBuffer).promise;
                    const totalPages = pdf.numPages;
                    let allRows = [];

                    for (let i = 1; i <= totalPages; i++) {
                        const page = await pdf.getPage(i);
                        const textContent = await page.getTextContent();
                        
                        const items = textContent.items.map(item => ({
                            str: item.str,
                            x: item.transform[4],
                            y: item.transform[5],
                            width: item.width,
                            height: item.height
                        }));

                        const rowsMap = new Map();
                        items.forEach(item => {
                            if (!item.str.trim() || item.str.trim() === ',') return;

                            let foundRowY = null;
                            for (let yKey of rowsMap.keys()) {
                                if (Math.abs(yKey - item.y) < 5) {
                                    foundRowY = yKey;
                                    break;
                                }
                            }

                            if (foundRowY !== null) {
                                rowsMap.get(foundRowY).push(item);
                            } else {
                                rowsMap.set(item.y, [item]);
                            }
                        });

                        rowsMap.forEach((rowItems) => {
                            rowItems.sort((a, b) => a.x - b.x);

                            const numericItems = rowItems
                                .map(item => ({...item, valStr: item.str.trim()}))
                                .filter(item => /^[\d,\-]+$/.test(item.valStr)); 
                            
                            if (numericItems.length >= 3) {
                                const parseNum = (s) => {
                                    if (s === '-') return 0;
                                    return parseInt(s.replace(/,/g, ''), 10);
                                };
                                
                                let age = null;
                                let dataStartIndex = 0;

                                const firstNum = parseNum(numericItems[0].valStr);
                                const secondNum = numericItems.length > 1 ? parseNum(numericItems[1].valStr) : -1;

                                if (firstNum < 150 && secondNum < 150) {
                                    age = Math.max(firstNum, secondNum);
                                    dataStartIndex = 2; 
                                } else if (firstNum < 150) {
                                    age = firstNum;
                                    dataStartIndex = 1; 
                                }

                                if (age !== null && age <= 109) {
                                    const potentialMoneyItems = numericItems.slice(dataStartIndex);
                                    if (potentialMoneyItems.length >= 2) {
                                        let accPremium = '-';
                                        if (potentialMoneyItems.length > 1) {
                                            accPremium = potentialMoneyItems[1].valStr;
                                        }
                                        const surrenderItem = potentialMoneyItems[potentialMoneyItems.length - 1]; 
                                        const insuranceItem = potentialMoneyItems[potentialMoneyItems.length - 2]; 

                                        allRows.push({
                                            id: Math.random().toString(36).substr(2, 9),
                                            age: age,
                                            accPremium: accPremium,
                                            insurance: insuranceItem.valStr,
                                            surrender: surrenderItem.valStr
                                        });
                                    }
                                }
                            }
                        });
                    }
                    
                    allRows.sort((a, b) => parseInt(a.age) - parseInt(b.age));
                    const uniqueRows = [];
                    const seenAges = new Set();
                    allRows.forEach(row => {
                        if (!seenAges.has(row.age)) {
                            seenAges.add(row.age);
                            uniqueRows.push(row);
                        }
                    });

